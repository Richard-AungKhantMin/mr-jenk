# =============================================
# Environment Variable Template
# Copy this file to .env and fill in real values.
# .env is git-ignored — NEVER commit real secrets!
#
# In Jenkins: credentials are stored in Jenkins Credentials Store
# and injected via withCredentials() in the Jenkinsfile.
# =============================================

# JWT Secret — used by identity-service, api-gateway, product-service, media-service
# Jenkins Credential ID: jwt-secret
JWT_SECRET=your-jwt-secret-here
